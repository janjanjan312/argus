# Required: Finnhub API key (free tier) — https://finnhub.io/register
FINNHUB_API_KEY=your_finnhub_key_here

# Required for L2 RAG: embeddings (ingest + retrieve_context). Same key works for LLM in test_query.py.
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# RAG vectors live under data/chroma_rag/ (Chroma persistent store); no extra env needed.
